# ============================================================
#  Bot-Audit — Environment Configuration
#  Copy this file to .env and fill in your real credentials.
# ============================================================

# ------ SMTP Settings ----------------------------------------
# Host of your outgoing mail server (e.g. smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# Port: 587 = STARTTLS (recommended), 465 = SSL/TLS
SMTP_PORT=587

# Use "true" only for port 465 (SSL). Leave "false" for STARTTLS.
SMTP_SECURE=false

# Your authenticated SMTP username (usually your email address)
SMTP_USER=your-email@gmail.com

# App password or SMTP password
# ⚠️  For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password-here

# ------ Sender Branding --------------------------------------
# The name that appears in the "From" field of every email
SENDER_NAME=Your Agency Name

# Your reply-to / from email address
SENDER_EMAIL=your-email@gmail.com

# ------ Browser Visibility & Crawl --------------------------
# Set to "false" to watch the bot scrape in a real browser window.
# Set to "true" (or leave out) to run silently in the background.
HEADLESS=true

# Maximum number of internal pages to crawl per website
# (1 = homepage only, 5 = home + up to 4 sub-pages)
MAX_PAGES=5

